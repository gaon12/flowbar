{
  "name": "flowbar",
  "version": "0.1.1",
  "description": "A zero-dependency progress toolkit for modern Node.js workflows.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/gaon12/flowbar#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gaon12/flowbar.git"
  },
  "bugs": {
    "url": "https://github.com/gaon12/flowbar/issues"
  },
  "keywords": [
    "progress",
    "progress-bar",
    "cli",
    "terminal",
    "typescript",
    "zero-dependency",
    "spinner",
    "stream",
    "async-iterator"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "src",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "llms.txt",
    "llms-full.txt"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check . && npm run check:lines",
    "lint:fix": "biome check --write .",
    "check:lines": "node scripts/check-file-length.mjs",
    "validate": "npm run lint && npm run typecheck && npm test && npm run check",
    "pretest": "npm run build",
    "test": "node --test",
    "check": "node --check dist/index.js",
    "prepack": "npm test",
    "prepare:zip": "npm test && node --check dist/index.js"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "^20.0.0",
    "typescript": "^5.8.0"
  }
}
